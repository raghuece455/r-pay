generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentStatus {
  CREATED
  PROCESSING
  SUCCESS
  FAILED
  PENDING
  TIMED_OUT
  RECONCILED
}

enum FailureReason {
  UPI_SWITCH_TIMEOUT
  BANK_TIMEOUT
  INSUFFICIENT_BALANCE
  INVALID_UPI_ID
  DUPLICATE_REQUEST
  RECONCILIATION_REQUIRED
  RATE_LIMITED
}

enum IncidentStatus {
  INVESTIGATING
  MITIGATING
  MONITORING
  RESOLVED
}

enum IncidentSeverity {
  SEV1
  SEV2
  SEV3
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  vpa          String        @unique
  createdAt    DateTime      @default(now())
  bankAccounts BankAccount[]
  payments     Payment[]
}

model BankAccount {
  id            String   @id @default(cuid())
  userId        String
  bankName      String
  maskedNumber  String
  accountType   String
  balancePaise  Int
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

model Payment {
  id               String           @id @default(cuid())
  userId           String
  payerVpa         String
  payeeVpa         String
  amountPaise      Int
  currency         String           @default("INR")
  note             String?
  status           PaymentStatus    @default(CREATED)
  failureReason    FailureReason?
  idempotencyKey   String
  mockSwitchRef    String?
  confirmedByMock  Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id])
  attempts         PaymentAttempt[]
  auditLogs        AuditLog[]

  @@unique([userId, idempotencyKey])
  @@index([status, createdAt])
}

model PaymentAttempt {
  id             String          @id @default(cuid())
  paymentId      String
  attemptNo      Int
  status         PaymentStatus
  failureReason  FailureReason?
  latencyMs      Int
  mockSwitchRef  String?
  requestJson    Json
  responseJson   Json
  createdAt      DateTime        @default(now())
  payment        Payment         @relation(fields: [paymentId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  paymentId   String?
  entityType  String
  entityId    String
  event       String
  actor       String
  metadata    Json
  createdAt   DateTime @default(now())
  payment     Payment? @relation(fields: [paymentId], references: [id])

  @@index([entityType, entityId, createdAt])
}

model MetricSnapshot {
  id                String   @id @default(cuid())
  successRate       Float
  failureRate       Float
  pendingCount      Int
  p95LatencyMs      Int
  queueDepth        Int
  dbPoolUsagePct    Int
  mockUpiLatencyMs  Int
  retryRate         Int
  serviceHealth     String
  createdAt         DateTime @default(now())
}

model Incident {
  id                    String                  @id @default(cuid())
  incidentKey           String                  @unique
  title                 String
  severity              IncidentSeverity
  status                IncidentStatus
  service               String
  summary               String
  investigationSummary  String?
  rootCause             String?
  startedAt             DateTime                @default(now())
  resolvedAt            DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  timeline              IncidentTimelineEvent[]
  rcaDrafts             RcaDraft[]
}

model IncidentTimelineEvent {
  id          String   @id @default(cuid())
  incidentId  String
  actor       String
  eventType   String
  message     String
  createdAt   DateTime @default(now())
  incident    Incident @relation(fields: [incidentId], references: [id])

  @@index([incidentId, createdAt])
}

model Deployment {
  id          String   @id @default(cuid())
  version     String
  service     String
  status      String
  deployedBy  String
  summary     String
  mode        String
  deployedAt  DateTime @default(now())
}

model OpsLog {
  id          String   @id @default(cuid())
  level       String
  service     String
  message     String
  traceId     String?
  paymentId   String?
  incidentId  String?
  metadata    Json
  createdAt   DateTime @default(now())

  @@index([service, createdAt])
  @@index([traceId])
}

model TraceSpan {
  id          String   @id @default(cuid())
  traceId     String
  spanName    String
  service     String
  durationMs  Int
  status      String
  paymentId   String?
  metadata    Json
  createdAt   DateTime @default(now())

  @@index([traceId])
}

model Runbook {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  body      String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model RcaDraft {
  id          String   @id @default(cuid())
  incidentId  String
  title       String
  body        String
  createdAt   DateTime @default(now())
  incident    Incident @relation(fields: [incidentId], references: [id])
}

